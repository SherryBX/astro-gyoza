---
import '@/styles/global.css'
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>评论管理 - Sherry's Blog</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg-primary: oklch(98% 0.005 280);
        --bg-secondary: oklch(96% 0.008 280);
        --bg-elevated: oklch(100% 0 0);
        --text-primary: oklch(25% 0.01 280);
        --text-secondary: oklch(50% 0.01 280);
        --text-tertiary: oklch(65% 0.008 280);
        --border: oklch(90% 0.005 280);
        --accent: oklch(60% 0.18 25);
        --accent-hover: oklch(55% 0.2 25);
        --success: oklch(65% 0.15 145);
        --warning: oklch(70% 0.15 85);
        --danger: oklch(60% 0.18 25);
        --shadow-sm: 0 1px 2px oklch(0% 0 0 / 0.05);
        --shadow-md: 0 4px 12px oklch(0% 0 0 / 0.08);
        --shadow-lg: 0 12px 32px oklch(0% 0 0 / 0.12);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg-primary: oklch(18% 0.01 280);
          --bg-secondary: oklch(22% 0.012 280);
          --bg-elevated: oklch(25% 0.015 280);
          --text-primary: oklch(95% 0.005 280);
          --text-secondary: oklch(75% 0.008 280);
          --text-tertiary: oklch(60% 0.01 280);
          --border: oklch(35% 0.01 280);
          --accent: oklch(75% 0.15 85);
          --accent-hover: oklch(80% 0.17 85);
          --success: oklch(75% 0.12 145);
          --warning: oklch(80% 0.12 85);
          --danger: oklch(70% 0.15 25);
        }
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue',
          sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .auth-overlay {
        position: fixed;
        inset: 0;
        background: oklch(0% 0 0 / 0.6);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.2s ease-out;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
      }

      .auth-box {
        background: var(--bg-elevated);
        padding: 48px;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        width: 90%;
        max-width: 420px;
        border: 1px solid var(--border);
        animation: slideUp 0.3s ease-out;
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
      }

      .auth-box h2 {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
      }

      .auth-box p {
        color: var(--text-secondary);
        font-size: 14px;
        margin-bottom: 32px;
      }

      .auth-box input {
        width: 100%;
        padding: 14px 16px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        font-size: 15px;
        background: var(--bg-secondary);
        color: var(--text-primary);
        transition: all 0.15s ease-out;
        margin-bottom: 16px;
      }

      .auth-box input:focus {
        outline: none;
        border-color: var(--accent);
        background: var(--bg-elevated);
        box-shadow: 0 0 0 3px oklch(from var(--accent) l c h / 0.1);
      }

      .auth-box input::placeholder {
        color: var(--text-tertiary);
      }

      .auth-error {
        color: var(--danger);
        font-size: 13px;
        margin-top: -12px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .auth-box button {
        width: 100%;
        padding: 14px;
        background: var(--accent);
        color: oklch(98% 0 0);
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease-out;
      }

      .auth-box button:hover {
        background: var(--accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }

      .auth-box button:active {
        transform: translateY(0);
      }

      .hidden {
        display: none;
      }

      .header {
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        padding: 24px 32px;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
      }

      .header-content {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .header h1 {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
      }

      .header-actions {
        display: flex;
        gap: 12px;
      }

      .btn-secondary {
        padding: 8px 16px;
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease-out;
      }

      .btn-secondary:hover {
        background: var(--bg-primary);
        border-color: var(--text-tertiary);
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 32px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
      }

      .stat-card {
        background: var(--bg-elevated);
        padding: 24px;
        border-radius: 12px;
        border: 1px solid var(--border);
        transition: all 0.2s ease-out;
      }

      .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }

      .stat-card h3 {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 12px;
      }

      .stat-card .number {
        font-size: 36px;
        font-weight: 700;
        color: var(--text-primary);
        font-variant-numeric: tabular-nums;
      }

      .comments-section {
        background: var(--bg-elevated);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
      }

      .comment {
        padding: 24px;
        border-bottom: 1px solid var(--border);
        transition: background 0.15s ease-out;
      }

      .comment:last-child {
        border-bottom: none;
      }

      .comment:hover {
        background: var(--bg-secondary);
      }

      .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
        gap: 16px;
      }

      .comment-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        font-size: 14px;
        color: var(--text-secondary);
      }

      .comment-meta strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      .comment-status {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
      }

      .status-approved {
        background: oklch(from var(--success) l c h / 0.15);
        color: var(--success);
      }

      .status-waiting {
        background: oklch(from var(--warning) l c h / 0.15);
        color: var(--warning);
      }

      .status-spam {
        background: oklch(from var(--danger) l c h / 0.15);
        color: var(--danger);
      }

      .comment-content {
        color: var(--text-primary);
        line-height: 1.7;
        margin-bottom: 12px;
        word-wrap: break-word;
      }

      .comment-url {
        font-size: 13px;
        color: var(--text-tertiary);
        margin-bottom: 16px;
        font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
      }

      .comment-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .btn {
        padding: 8px 14px;
        border: none;
        border-radius: 7px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease-out;
      }

      .btn-approve {
        background: oklch(from var(--success) l c h / 0.15);
        color: var(--success);
      }

      .btn-approve:hover {
        background: oklch(from var(--success) l c h / 0.25);
      }

      .btn-spam {
        background: oklch(from var(--warning) l c h / 0.15);
        color: var(--warning);
      }

      .btn-spam:hover {
        background: oklch(from var(--warning) l c h / 0.25);
      }

      .btn-delete {
        background: oklch(from var(--danger) l c h / 0.15);
        color: var(--danger);
      }

      .btn-delete:hover {
        background: oklch(from var(--danger) l c h / 0.25);
      }

      .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        padding: 32px 0;
      }

      .pagination button {
        padding: 10px 18px;
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        color: var(--text-primary);
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease-out;
      }

      .pagination button:hover:not(:disabled) {
        border-color: var(--accent);
        color: var(--accent);
      }

      .pagination button:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }

      .pagination span {
        color: var(--text-secondary);
        font-size: 14px;
        font-variant-numeric: tabular-nums;
      }

      .loading,
      .empty {
        text-align: center;
        padding: 64px 32px;
        color: var(--text-secondary);
      }

      .loading::before {
        content: '';
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 16px;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      @media (max-width: 768px) {
        .container {
          padding: 20px 16px;
        }

        .header {
          padding: 20px 16px;
        }

        .auth-box {
          padding: 32px 24px;
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .comment {
          padding: 20px 16px;
        }

        .comment-header {
          flex-direction: column;
        }

        .comment-meta {
          flex-direction: column;
          gap: 8px;
        }
      }
    </style>
  </head>
  <body>
    <div id="authOverlay" class="auth-overlay">
      <div class="auth-box">
        <h2>管理员登录</h2>
        <p>请输入访问口令以继续</p>
        <input
          type="password"
          id="passwordInput"
          placeholder="输入口令"
          autocomplete="off"
        />
        <div id="authError" class="auth-error hidden">
          <span>⚠</span>
          <span>口令错误，请重试</span>
        </div>
        <button id="loginButton">登录</button>
      </div>
    </div>

    <div id="mainContent" class="hidden">
      <div class="header">
        <div class="header-content">
          <h1>评论管理</h1>
          <div class="header-actions">
            <button class="btn-secondary" onclick="location.reload()">刷新</button>
            <button class="btn-secondary" onclick="location.href='/'">返回首页</button>
          </div>
        </div>
      </div>

      <div class="container">
        <div class="stats">
          <div class="stat-card">
            <h3>总评论数</h3>
            <div class="number" id="totalComments">-</div>
          </div>
          <div class="stat-card">
            <h3>待审核</h3>
            <div class="number" id="pendingComments">-</div>
          </div>
          <div class="stat-card">
            <h3>已通过</h3>
            <div class="number" id="approvedComments">-</div>
          </div>
        </div>

        <div class="comments-section" id="commentsList">
          <div class="loading">加载中</div>
        </div>

        <div class="pagination" id="pagination"></div>
      </div>
    </div>

    <script>
      const CORRECT_PASSWORD = 'Sherry77'
      const API_BASE = 'https://waline.sherry-account.workers.dev'
      let currentPage = 1
      const pageSize = 20

      function checkPassword() {
        const input = document.getElementById('passwordInput')
        const error = document.getElementById('authError')
        const password = input.value.trim()

        if (password === CORRECT_PASSWORD) {
          sessionStorage.setItem('comments_auth', 'true')
          document.getElementById('authOverlay').classList.add('hidden')
          document.getElementById('mainContent').classList.remove('hidden')
          loadComments()
        } else {
          error.classList.remove('hidden')
          input.value = ''
          input.focus()
        }
      }

      document.getElementById('loginButton').addEventListener('click', checkPassword)

      document.getElementById('passwordInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          checkPassword()
        }
      })

      window.addEventListener('DOMContentLoaded', () => {
        const isAuthenticated = sessionStorage.getItem('comments_auth') === 'true'
        if (isAuthenticated) {
          document.getElementById('authOverlay').classList.add('hidden')
          document.getElementById('mainContent').classList.remove('hidden')
          loadComments()
        } else {
          document.getElementById('passwordInput').focus()
        }
      })

      async function loadComments() {
        try {
          const res = await fetch(`${API_BASE}/api/admin/comments?page=${currentPage}&pageSize=${pageSize}`)
          const data = await res.json()

          if (data.errno === 0) {
            renderComments(data.data.comments)
            renderPagination(data.data.count)
            updateStats(data.data.comments)
          }
        } catch (error) {
          document.getElementById('commentsList').innerHTML = '<div class="empty">加载失败</div>'
        }
      }

      function renderComments(comments) {
        const container = document.getElementById('commentsList')

        if (comments.length === 0) {
          container.innerHTML = '<div class="empty">暂无评论</div>'
          return
        }

        container.innerHTML = comments
          .map(
            (comment) => `
        <div class="comment" data-id="${comment.id}">
          <div class="comment-header">
            <div class="comment-meta">
              <span><strong>${comment.nick || '匿名'}</strong></span>
              ${comment.mail ? `<span>${comment.mail}</span>` : ''}
              <span>${new Date(comment.insertedAt).toLocaleString('zh-CN')}</span>
            </div>
            <span class="comment-status status-${comment.status}">${getStatusText(comment.status)}</span>
          </div>
          <div class="comment-content">${escapeHtml(comment.comment)}</div>
          <div class="comment-url">${comment.url}</div>
          <div class="comment-actions">
            ${comment.status !== 'approved' ? `<button class="btn btn-approve" onclick="updateStatus(${comment.id}, 'approved')">通过</button>` : ''}
            ${comment.status !== 'spam' ? `<button class="btn btn-spam" onclick="updateStatus(${comment.id}, 'spam')">标记垃圾</button>` : ''}
            <button class="btn btn-delete" onclick="deleteComment(${comment.id})">删除</button>
          </div>
        </div>
      `,
          )
          .join('')
      }

      function renderPagination(total) {
        const totalPages = Math.ceil(total / pageSize)
        const container = document.getElementById('pagination')

        if (totalPages <= 1) {
          container.innerHTML = ''
          return
        }

        container.innerHTML = `
        <button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
        <span>第 ${currentPage} / ${totalPages} 页</span>
        <button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
      `
      }

      function updateStats(comments) {
        document.getElementById('totalComments').textContent = comments.length
        document.getElementById('pendingComments').textContent = comments.filter(
          (c) => c.status === 'waiting',
        ).length
        document.getElementById('approvedComments').textContent = comments.filter(
          (c) => c.status === 'approved',
        ).length
      }

      async function deleteComment(id) {
        if (!confirm('确定要删除这条评论吗？')) return

        try {
          await fetch(`${API_BASE}/api/admin/comment/${id}`, { method: 'DELETE' })
          loadComments()
        } catch (error) {
          alert('删除失败')
        }
      }

      async function updateStatus(id, status) {
        try {
          await fetch(`${API_BASE}/api/admin/comment/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status }),
          })
          loadComments()
        } catch (error) {
          alert('更新失败')
        }
      }

      function changePage(page) {
        currentPage = page
        loadComments()
        window.scrollTo({ top: 0, behavior: 'smooth' })
      }

      function getStatusText(status) {
        const map = { approved: '已通过', waiting: '待审核', spam: '垃圾评论' }
        return map[status] || status
      }

      function escapeHtml(text) {
        const div = document.createElement('div')
        div.textContent = text
        return div.innerHTML
      }
    </script>
  </body>
</html>
