---
import '@/styles/global.css'
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>评论管理 - Sherry's Blog</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg-primary: oklch(98.5% 0.003 280);
        --bg-secondary: oklch(96.5% 0.005 280);
        --bg-elevated: oklch(99.5% 0.002 280);
        --text-primary: oklch(22% 0.015 280);
        --text-secondary: oklch(48% 0.012 280);
        --text-tertiary: oklch(62% 0.01 280);
        --border: oklch(92% 0.004 280);
        --accent: oklch(58% 0.16 260);
        --accent-hover: oklch(52% 0.18 260);
        --accent-soft: oklch(58% 0.16 260 / 0.12);
        --success: oklch(62% 0.14 150);
        --success-soft: oklch(62% 0.14 150 / 0.12);
        --warning: oklch(68% 0.13 80);
        --warning-soft: oklch(68% 0.13 80 / 0.12);
        --danger: oklch(58% 0.16 25);
        --danger-soft: oklch(58% 0.16 25 / 0.12);
        --shadow-sm: 0 1px 3px oklch(0% 0 0 / 0.04), 0 1px 2px oklch(0% 0 0 / 0.02);
        --shadow-md: 0 4px 16px oklch(0% 0 0 / 0.06), 0 2px 8px oklch(0% 0 0 / 0.04);
        --shadow-lg: 0 12px 40px oklch(0% 0 0 / 0.08), 0 4px 16px oklch(0% 0 0 / 0.06);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg-primary: oklch(17% 0.012 280);
          --bg-secondary: oklch(20% 0.015 280);
          --bg-elevated: oklch(23% 0.018 280);
          --text-primary: oklch(96% 0.004 280);
          --text-secondary: oklch(72% 0.008 280);
          --text-tertiary: oklch(58% 0.01 280);
          --border: oklch(32% 0.012 280);
          --accent: oklch(72% 0.14 260);
          --accent-hover: oklch(78% 0.16 260);
          --accent-soft: oklch(72% 0.14 260 / 0.15);
          --success: oklch(70% 0.12 150);
          --success-soft: oklch(70% 0.12 150 / 0.15);
          --warning: oklch(75% 0.11 80);
          --warning-soft: oklch(75% 0.11 80 / 0.15);
          --danger: oklch(68% 0.14 25);
          --danger-soft: oklch(68% 0.14 25 / 0.15);
        }
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue',
          sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .auth-overlay {
        position: fixed;
        inset: 0;
        background: oklch(0% 0 0 / 0.5);
        backdrop-filter: blur(12px) saturate(1.2);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
      }

      .auth-box {
        background: var(--bg-elevated);
        padding: 56px 48px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        width: 90%;
        max-width: 440px;
        border: 1px solid var(--border);
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(24px) scale(0.96);
        }
      }

      .auth-box h2 {
        font-size: 28px;
        font-weight: 650;
        margin-bottom: 10px;
        color: var(--text-primary);
        letter-spacing: -0.02em;
      }

      .auth-box p {
        color: var(--text-secondary);
        font-size: 15px;
        margin-bottom: 36px;
        line-height: 1.5;
      }

      .auth-box input {
        width: 100%;
        padding: 16px 18px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 16px;
        background: var(--bg-secondary);
        color: var(--text-primary);
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        margin-bottom: 18px;
        font-family: inherit;
      }

      .auth-box input:focus {
        outline: none;
        border-color: var(--accent);
        background: var(--bg-elevated);
        box-shadow: 0 0 0 4px var(--accent-soft);
        transform: translateY(-1px);
      }

      .auth-box input::placeholder {
        color: var(--text-tertiary);
      }

      .auth-error {
        color: var(--danger);
        font-size: 14px;
        margin-top: -14px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: var(--danger-soft);
        border-radius: var(--radius-sm);
        animation: shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97);
      }

      @keyframes shake {
        0%,
        100% {
          transform: translateX(0);
        }
        25% {
          transform: translateX(-8px);
        }
        75% {
          transform: translateX(8px);
        }
      }

      .auth-box button {
        width: 100%;
        padding: 16px;
        background: var(--accent);
        color: oklch(99% 0 0);
        border: none;
        border-radius: var(--radius-md);
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        font-family: inherit;
      }

      .auth-box button:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }

      .auth-box button:active {
        transform: translateY(0);
      }

      .hidden {
        display: none;
      }

      .header {
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        padding: 28px 40px;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(16px) saturate(1.8);
        box-shadow: var(--shadow-sm);
      }

      .header-content {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .header h1 {
        font-size: 22px;
        font-weight: 650;
        color: var(--text-primary);
        letter-spacing: -0.02em;
      }

      .header-actions {
        display: flex;
        gap: 10px;
      }

      .btn-secondary {
        padding: 10px 18px;
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        font-family: inherit;
      }

      .btn-secondary:hover {
        background: var(--bg-primary);
        border-color: var(--text-tertiary);
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
      }

      .btn-secondary:active {
        transform: translateY(0);
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 40px 60px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
        margin-bottom: 40px;
      }

      .stat-card {
        background: var(--bg-elevated);
        padding: 28px 32px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
      }

      .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-hover));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--accent);
      }

      .stat-card:hover::before {
        transform: scaleX(1);
      }

      .stat-card h3 {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 16px;
      }

      .stat-card .number {
        font-size: 42px;
        font-weight: 700;
        color: var(--text-primary);
        font-variant-numeric: tabular-nums;
        line-height: 1;
        letter-spacing: -0.03em;
      }

      .comments-section {
        background: var(--bg-elevated);
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
      }

      .comment {
        padding: 28px 32px;
        border-bottom: 1px solid var(--border);
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
      }

      .comment::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--accent);
        transform: scaleY(0);
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .comment:last-child {
        border-bottom: none;
      }

      .comment:hover {
        background: var(--bg-secondary);
      }

      .comment:hover::before {
        transform: scaleY(1);
      }

      .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
        gap: 20px;
      }

      .comment-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        font-size: 14px;
        color: var(--text-secondary);
        align-items: center;
      }

      .comment-meta strong {
        color: var(--text-primary);
        font-weight: 600;
        font-size: 15px;
      }

      .comment-status {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
        letter-spacing: 0.3px;
        text-transform: uppercase;
      }

      .status-approved {
        background: var(--success-soft);
        color: var(--success);
      }

      .status-waiting {
        background: var(--warning-soft);
        color: var(--warning);
      }

      .status-spam {
        background: var(--danger-soft);
        color: var(--danger);
      }

      .comment-content {
        color: var(--text-primary);
        line-height: 1.7;
        margin-bottom: 14px;
        word-wrap: break-word;
        font-size: 15px;
      }

      .comment-url {
        font-size: 13px;
        color: var(--text-tertiary);
        margin-bottom: 18px;
        font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Consolas', monospace;
        padding: 8px 12px;
        background: var(--bg-secondary);
        border-radius: var(--radius-sm);
        display: inline-block;
      }

      .comment-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .btn {
        padding: 9px 16px;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        font-family: inherit;
        letter-spacing: 0.2px;
      }

      .btn-approve {
        background: var(--success-soft);
        color: var(--success);
      }

      .btn-approve:hover {
        background: oklch(from var(--success) l c h / 0.2);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px oklch(from var(--success) l c h / 0.2);
      }

      .btn-spam {
        background: var(--warning-soft);
        color: var(--warning);
      }

      .btn-spam:hover {
        background: oklch(from var(--warning) l c h / 0.2);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px oklch(from var(--warning) l c h / 0.2);
      }

      .btn-delete {
        background: var(--danger-soft);
        color: var(--danger);
      }

      .btn-delete:hover {
        background: oklch(from var(--danger) l c h / 0.2);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px oklch(from var(--danger) l c h / 0.2);
      }

      .btn:active {
        transform: translateY(0);
      }

      .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        padding: 40px 0;
      }

      .pagination button {
        padding: 11px 20px;
        border: 1.5px solid var(--border);
        background: var(--bg-elevated);
        color: var(--text-primary);
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        font-family: inherit;
      }

      .pagination button:hover:not(:disabled) {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
      }

      .pagination button:active:not(:disabled) {
        transform: translateY(0);
      }

      .pagination button:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      .pagination span {
        color: var(--text-secondary);
        font-size: 14px;
        font-variant-numeric: tabular-nums;
        font-weight: 500;
        padding: 0 8px;
      }

      .loading,
      .empty {
        text-align: center;
        padding: 80px 32px;
        color: var(--text-secondary);
        font-size: 15px;
      }

      .loading::before {
        content: '';
        display: inline-block;
        width: 32px;
        height: 32px;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin-bottom: 20px;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .empty {
        color: var(--text-tertiary);
      }

      @media (max-width: 768px) {
        .container {
          padding: 24px 20px 48px;
        }

        .header {
          padding: 20px 20px;
        }

        .header h1 {
          font-size: 19px;
        }

        .header-actions {
          gap: 8px;
        }

        .btn-secondary {
          padding: 8px 14px;
          font-size: 13px;
        }

        .auth-box {
          padding: 40px 32px;
          max-width: 90%;
        }

        .auth-box h2 {
          font-size: 24px;
        }

        .stats {
          grid-template-columns: 1fr;
          gap: 16px;
        }

        .stat-card {
          padding: 24px 28px;
        }

        .stat-card .number {
          font-size: 38px;
        }

        .comment {
          padding: 24px 20px;
        }

        .comment-header {
          flex-direction: column;
          gap: 12px;
          align-items: flex-start;
        }

        .comment-meta {
          flex-direction: column;
          gap: 10px;
          align-items: flex-start;
        }

        .comment-status {
          align-self: flex-start;
        }

        .comment-content {
          font-size: 14px;
        }

        .comment-url {
          font-size: 12px;
          word-break: break-all;
        }

        .comment-actions {
          width: 100%;
        }

        .comment-actions .btn {
          flex: 1;
          min-width: 0;
        }

        .pagination {
          padding: 32px 0;
          gap: 10px;
        }

        .pagination button {
          padding: 10px 16px;
          font-size: 13px;
        }

        .pagination span {
          font-size: 13px;
        }
      }

      @media (max-width: 480px) {
        .auth-box {
          padding: 32px 24px;
        }

        .auth-box h2 {
          font-size: 22px;
        }

        .header h1 {
          font-size: 18px;
        }

        .stat-card .number {
          font-size: 34px;
        }

        .comment-actions {
          flex-direction: column;
        }

        .comment-actions .btn {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div id="authOverlay" class="auth-overlay">
      <div class="auth-box">
        <h2>管理员登录</h2>
        <p>请输入访问口令以继续</p>
        <input
          type="password"
          id="passwordInput"
          placeholder="输入口令"
          autocomplete="off"
        />
        <div id="authError" class="auth-error hidden">
          <span>⚠</span>
          <span>口令错误，请重试</span>
        </div>
        <button id="loginButton">登录</button>
      </div>
    </div>

    <div id="mainContent" class="hidden">
      <div class="header">
        <div class="header-content">
          <h1>评论管理</h1>
          <div class="header-actions">
            <button class="btn-secondary" onclick="location.reload()">刷新</button>
            <button class="btn-secondary" onclick="location.href='/'">返回首页</button>
          </div>
        </div>
      </div>

      <div class="container">
        <div class="stats">
          <div class="stat-card">
            <h3>总评论数</h3>
            <div class="number" id="totalComments">-</div>
          </div>
          <div class="stat-card">
            <h3>待审核</h3>
            <div class="number" id="pendingComments">-</div>
          </div>
          <div class="stat-card">
            <h3>已通过</h3>
            <div class="number" id="approvedComments">-</div>
          </div>
        </div>

        <div class="comments-section" id="commentsList">
          <div class="loading">加载中</div>
        </div>

        <div class="pagination" id="pagination"></div>
      </div>
    </div>

    <script>
      const CORRECT_PASSWORD = 'Sherry77'
      const API_BASE = 'https://waline.sherry-account.workers.dev'
      let currentPage = 1
      const pageSize = 20

      function checkPassword() {
        const input = document.getElementById('passwordInput')
        const error = document.getElementById('authError')
        const password = input.value.trim()

        if (password === CORRECT_PASSWORD) {
          sessionStorage.setItem('comments_auth', 'true')
          document.getElementById('authOverlay').classList.add('hidden')
          document.getElementById('mainContent').classList.remove('hidden')
          loadComments()
        } else {
          error.classList.remove('hidden')
          input.value = ''
          input.focus()
        }
      }

      document.getElementById('loginButton').addEventListener('click', checkPassword)

      document.getElementById('passwordInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          checkPassword()
        }
      })

      window.addEventListener('DOMContentLoaded', () => {
        const isAuthenticated = sessionStorage.getItem('comments_auth') === 'true'
        if (isAuthenticated) {
          document.getElementById('authOverlay').classList.add('hidden')
          document.getElementById('mainContent').classList.remove('hidden')
          loadComments()
        } else {
          document.getElementById('passwordInput').focus()
        }
      })

      async function loadComments() {
        try {
          const res = await fetch(`${API_BASE}/api/admin/comments?page=${currentPage}&pageSize=${pageSize}`)
          const data = await res.json()

          if (data.errno === 0) {
            renderComments(data.data.comments)
            renderPagination(data.data.count)
            updateStats(data.data)
          }
        } catch (error) {
          document.getElementById('commentsList').innerHTML = '<div class="empty">加载失败</div>'
        }
      }

      function renderComments(comments) {
        const container = document.getElementById('commentsList')

        if (comments.length === 0) {
          container.innerHTML = '<div class="empty" data-astro-cid-orxeznep>暂无评论</div>'
          return
        }

        container.innerHTML = comments
          .map(
            (comment) => `
        <div class="comment" data-id="${comment.id}" data-astro-cid-orxeznep>
          <div class="comment-header" data-astro-cid-orxeznep>
            <div class="comment-meta" data-astro-cid-orxeznep>
              <span data-astro-cid-orxeznep><strong data-astro-cid-orxeznep>${comment.nick || '匿名'}</strong></span>
              ${comment.mail ? `<span data-astro-cid-orxeznep>${comment.mail}</span>` : ''}
              <span data-astro-cid-orxeznep>${new Date(comment.insertedAt).toLocaleString('zh-CN')}</span>
            </div>
            <span class="comment-status status-${comment.status}" data-astro-cid-orxeznep>${getStatusText(comment.status)}</span>
          </div>
          <div class="comment-content" data-astro-cid-orxeznep>${escapeHtml(comment.comment)}</div>
          <div class="comment-url" data-astro-cid-orxeznep>${comment.url}</div>
          <div class="comment-actions" data-astro-cid-orxeznep>
            ${comment.status !== 'approved' ? `<button class="btn btn-approve" data-astro-cid-orxeznep onclick="updateStatus(${comment.id}, 'approved')">通过</button>` : ''}
            ${comment.status !== 'spam' ? `<button class="btn btn-spam" data-astro-cid-orxeznep onclick="updateStatus(${comment.id}, 'spam')">标记垃圾</button>` : ''}
            <button class="btn btn-delete" data-astro-cid-orxeznep onclick="deleteComment(${comment.id})">删除</button>
          </div>
        </div>
      `,
          )
          .join('')
      }

      function renderPagination(total) {
        const totalPages = Math.ceil(total / pageSize)
        const container = document.getElementById('pagination')

        if (totalPages <= 1) {
          container.innerHTML = ''
          return
        }

        container.innerHTML = `
        <button data-astro-cid-orxeznep onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
        <span data-astro-cid-orxeznep>第 ${currentPage} / ${totalPages} 页</span>
        <button data-astro-cid-orxeznep onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
      `
      }

      function updateStats(data) {
        if (data.stats) {
          document.getElementById('totalComments').textContent = data.stats.total
          document.getElementById('pendingComments').textContent = data.stats.waiting
          document.getElementById('approvedComments').textContent = data.stats.approved
        } else {
          // Fallback for old API response
          document.getElementById('totalComments').textContent = data.count || 0
          document.getElementById('pendingComments').textContent = data.comments.filter(
            (c) => c.status === 'waiting',
          ).length
          document.getElementById('approvedComments').textContent = data.comments.filter(
            (c) => c.status === 'approved',
          ).length
        }
      }

      async function deleteComment(id) {
        if (!confirm('确定要删除这条评论吗？')) return

        try {
          await fetch(`${API_BASE}/api/admin/comment/${id}`, { method: 'DELETE' })
          loadComments()
        } catch (error) {
          alert('删除失败')
        }
      }

      async function updateStatus(id, status) {
        try {
          await fetch(`${API_BASE}/api/admin/comment/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status }),
          })
          loadComments()
        } catch (error) {
          alert('更新失败')
        }
      }

      function changePage(page) {
        currentPage = page
        loadComments()
        window.scrollTo({ top: 0, behavior: 'smooth' })
      }

      function getStatusText(status) {
        const map = { approved: '已通过', waiting: '待审核', spam: '垃圾评论' }
        return map[status] || status
      }

      function escapeHtml(text) {
        const div = document.createElement('div')
        div.textContent = text
        return div.innerHTML
      }

      // Expose functions to global scope for inline event handlers
      window.deleteComment = deleteComment
      window.updateStatus = updateStatus
      window.changePage = changePage
    </script>
  </body>
</html>
